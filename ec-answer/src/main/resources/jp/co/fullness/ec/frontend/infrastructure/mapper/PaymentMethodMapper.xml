<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="jp.co.fullness.ec.frontend.infrastructure.mapper.PaymentMethodMapper">

    <select id="selectAll" resultType="PaymentMethodEntity">
        SELECT id, name FROM payment_method ORDER BY id
    </select>

    <select id="selectById" resultType="PaymentMethodEntity" parameterType="int">
        SELECT id, name FROM payment_method WHERE id = #{id}
    </select>

</mapper>