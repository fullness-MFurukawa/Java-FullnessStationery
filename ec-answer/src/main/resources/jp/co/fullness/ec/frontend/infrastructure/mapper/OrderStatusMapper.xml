<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="jp.co.fullness.ec.frontend.infrastructure.mapper.OrderStatusMapper">

    <select id="selectAll" resultType="OrderStatusEntity">
        SELECT id, name FROM order_status ORDER BY id
    </select>

    <select id="selectById" resultType="OrderStatusEntity" parameterType="int">
        SELECT id, name FROM order_status WHERE id = #{id}
    </select>

</mapper>