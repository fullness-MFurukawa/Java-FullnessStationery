<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="jp.co.fullness.ec.frontend.infrastructure.mapper.ProductCategoryMapper">

    <select id="selectAll" resultType="ProductCategoryEntity">
        SELECT id, name FROM product_category ORDER BY id
    </select>

    <select id="selectById" resultType="ProductCategoryEntity" parameterType="int">
        SELECT id, name FROM product_category WHERE id = #{id}
    </select>

</mapper>