<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="jp.co.fullness.ec.backend.infrastructure.mapper.DepartmentMapper">

    <!-- IDで部署を1件取得 -->
    <select id="selectById" resultType="DepartmentEntity">
        SELECT
            id,
            name
        FROM
            department
        WHERE
            id = #{id}
    </select>

</mapper>