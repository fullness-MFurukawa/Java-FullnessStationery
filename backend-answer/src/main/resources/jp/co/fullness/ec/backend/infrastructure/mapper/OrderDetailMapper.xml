<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="jp.co.fullness.ec.backend.infrastructure.mapper.OrderDetailMapper">

    <select id="selectByOrderId" resultType="OrderDetailEntity" parameterType="int">
        SELECT id, order_id, product_id, count
          FROM orders_detail
         WHERE order_id = #{orderId}
         ORDER BY id
    </select>

</mapper>